say "--- Royal  Calculatoin --"
say ""

set num1 to 20
set num2 to 10

set num3 to num1 + num2
say "The Royal Sum is: " + num3
set num3 to num1 - num2
say "The Royal sub is: " + num3
set num3 to num1 * num2
say "The Royal Mul is: " + num3
set num3 to num1 / num2
say "The Royal Div is: " + num3
set num3 to num1 % num2
say "The Royal Mod is: " + num3